datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Story model
model Story {
  id         String   @id @default(uuid())
  name       String
  image      String
  avatar     String?
  type       String   @default("upload")
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// Course model
model Course {
  id          String   @id // Dạng slug (ví dụ: "tieng-anh-9-he-2k12")
  title       String
  thumbnail   String?
  teachers    Json?    // Mảng JSON lưu tên giáo viên: ["Cô Dung", "Tổ Tiếng Anh"]
  videos      String?  // Ví dụ: "12 Video"
  exercises   String?  // Ví dụ: "0 Bài tập"
  exams       String?  // Ví dụ: "0 Bài thi"
  priceMain   String?  // Ví dụ: "300.000"
  priceSale   String?  // Ví dụ: "200.000"
  saleTag     String?  // Ví dụ: "33%"
  grade       String   // Lớp: "8" | "9" | "10" | "11" | "12"
  isHot       Boolean  @default(false)
  hotIcon     String?
  createdAt   DateTime @default(now())
  lessons     Lesson[]
}

// Lesson model
model Lesson {
  id            String    @id @default(uuid())
  title         String
  videoUrl      String?
  duration      String
  thumbnail     String?
  playlistId    String?
  course        Course?   @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  exerciseId    String?
  documents     Json?
  quizPoints    Json?
  homeworkTasks Json?
  createdAt     DateTime  @default(now())
  comments      Comment[]
}

// Comment model
model Comment {
  id         String   @id @default(uuid())
  userName   String
  userAvatar String?
  content    String
  createdAt  DateTime @default(now())
  lessonId   String?
  lesson     Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// FlashcardDeck model
model FlashcardDeck {
  id            String          @id @default(uuid())
  category      String
  categoryLabel String
  title         String
  cardCount     Int             @default(0)
  isLocked      Boolean         @default(false)
  type          String          @default("system") // "system" | "custom"
  createdAt     DateTime        @default(now())
  cards         FlashcardCard[]
}

// FlashcardCard model
model FlashcardCard {
  id        String        @id @default(uuid())
  deckId    String
  front     String
  back      String
  deck      FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

// Exam model
model Exam {
  id          String     @id @default(uuid())
  title       String
  category    String     // "school-exams" | "mock-test" | "progress-test"
  duration    Int        // in minutes
  cardCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  questions   Question[]
}

// Question model
model Question {
  id            String   @id @default(uuid())
  examId        String
  number        Int
  text          String
  options       Json     // Store options as { A: "text", B: "text", C: "text", D: "text" }
  correctAnswer String   // "A" | "B" | "C" | "D" or string for open-ended
  explanation   String?
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

// User model
model User {
  id             String         @id @default(uuid())
  username       String         @unique
  password       String
  plainPassword  String?
  name           String
  role           String         @default("student") // "admin" | "student"
  allowedCourses Json?          // Danh sách khóa học được phép học (ví dụ: ["toan-9-he-2k12"])
  allowedExams   Json?          // Danh sách đề thi được làm (ví dụ: ["progress-test-1"])
  createdAt      DateTime       @default(now())
  notifications  Notification[]
  targetOverall   String?
  targetReading   String?
  targetListening String?
  targetWriting   String?
  targetSpeaking  String?
  examDate        String?       // Format: YYYY-MM-DD
}

// Notification model
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   @default("info") // "info" | "success" | "warning" | "alert"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
